# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get this from: Supabase Dashboard → Settings → Database → Connection String → URI
# Replace [YOUR-PASSWORD] with your Supabase project password
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?schema=public"

# ─── Football-Data.org API ────────────────────────────────────────────────────
FOOTBALL_DATA_API_KEY=ea8aabeb96ca49b6bca3b2f42119f197
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# ─── FIFA World Cup 2026 Competition ID on football-data.org ─────────────────
# Competition code for FIFA World Cup is WC
WC_COMPETITION_CODE=WC

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# ─── Brevo Transactional Email ────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=verified_sender@example.com
BREVO_SENDER_NAME=WorldCupBet
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
