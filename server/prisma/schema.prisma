// This is your Prisma schema file
// Learn more at https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum BetStatus {
  PENDING
  WON
  LOST
  CANCELLED
  REFUNDED
}

enum MarketType {
  HOME_WIN
  DRAW
  AWAY_WIN
  OVER_1_5
  OVER_2_5
  OVER_3_5
  UNDER_1_5
  UNDER_2_5
  UNDER_3_5
  DOUBLE_CHANCE_1X
  DOUBLE_CHANCE_X2
  DOUBLE_CHANCE_12
  CORRECT_SCORE
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_WIN
  BET_REFUND
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum DepositRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  username                   String    @unique
  passwordHash               String
  role                       UserRole  @default(USER)
  isActive                   Boolean   @default(true)
  emailVerified              Boolean   @default(true)
  emailVerificationCodeHash  String?
  emailVerificationExpiresAt DateTime?
  emailVerificationSentAt    DateTime?
  welcomeBonusClaimed        Boolean   @default(false)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  wallet          Wallet?
  bets            Bet[]
  betCoupons      BetCoupon[]
  transactions    Transaction[]
  withdrawals     Withdrawal[]
  depositRequests DepositRequest[]
  notifications   UserNotification[]
  auditLogs       AuditLog[]

  @@map("users")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  currency  String   @default("EUR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Match {
  id           String      @id @default(cuid())
  externalId   Int         @unique // ID from football-data.org
  homeTeam     String
  awayTeam     String
  homeTeamCode String // e.g. "BRA"
  awayTeamCode String // e.g. "FRA"
  kickoffTime  DateTime
  competition  String      @default("FIFA World Cup 2026")
  stage        String? // Group Stage, Quarter-Final, etc.
  group        String? // Group A, Group B, etc.
  status       MatchStatus @default(SCHEDULED)
  homeScore    Int?
  awayScore    Int?
  oddsLockedAt DateTime? // Set when match starts — odds frozen
  settledAt    DateTime? // Set after bets are settled
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  odds        Odds[]
  bets        Bet[]
  settlements Settlement[]

  @@map("matches")
}

model Odds {
  id           String     @id @default(cuid())
  matchId      String
  marketType   MarketType
  selection    String // e.g. "HOME", "2-1", "OVER"
  probability  Decimal    @db.Decimal(6, 4)
  odds         Decimal    @db.Decimal(8, 4) // European format
  isLocked     Boolean    @default(false)
  calculatedAt DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  bets  Bet[]

  @@unique([matchId, marketType, selection])
  @@map("odds")
}

model Bet {
  id              String     @id @default(cuid())
  userId          String
  matchId         String
  oddsId          String
  marketType      MarketType
  selectedOption  String // e.g. "HOME", "OVER_2_5", "2-1"
  oddsAtPlacement Decimal    @db.Decimal(8, 4)
  stakeAmount     Decimal    @db.Decimal(15, 2)
  potentialWin    Decimal    @db.Decimal(15, 2)
  status          BetStatus  @default(PENDING)
  placedAt        DateTime   @default(now())
  settledAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  match      Match       @relation(fields: [matchId], references: [id])
  oddsRecord Odds        @relation(fields: [oddsId], references: [id])
  settlement Settlement?

  @@map("bets")
}

model BetCoupon {
  id             String    @id @default(cuid())
  userId         String
  selections     Json
  selectionCount Int
  totalOdds      Decimal   @db.Decimal(12, 4)
  stakeAmount    Decimal   @db.Decimal(15, 2)
  potentialWin   Decimal   @db.Decimal(15, 2)
  status         BetStatus @default(PENDING)
  placedAt       DateTime  @default(now())
  settledAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("bet_coupons")
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  balanceBefore Decimal         @db.Decimal(15, 2)
  balanceAfter  Decimal         @db.Decimal(15, 2)
  description   String?
  referenceId   String? // betId or withdrawalId
  createdAt     DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model Withdrawal {
  id          String           @id @default(cuid())
  userId      String
  amount      Decimal          @db.Decimal(15, 2)
  method      String // "MOBILE_MONEY" | "CRYPTO"
  destination String // phone number or wallet address
  status      WithdrawalStatus @default(PENDING)
  adminNote   String?
  processedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("withdrawals")
}

model DepositRequest {
  id            String               @id @default(cuid())
  userId        String
  amount        Decimal              @db.Decimal(15, 2)
  method        String
  reference     String
  screenshotUrl String?
  status        DepositRequestStatus @default(PENDING)
  adminNote     String?
  processedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("deposit_requests")
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Settlement {
  id               String    @id @default(cuid())
  matchId          String
  betId            String    @unique
  settlementResult BetStatus // WON | LOST | REFUNDED
  payoutAmount     Decimal   @default(0) @db.Decimal(15, 2)
  settledAt        DateTime  @default(now())

  match Match @relation(fields: [matchId], references: [id])
  bet   Bet   @relation(fields: [betId], references: [id])

  @@map("settlements")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
